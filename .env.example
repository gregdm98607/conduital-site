# Conduital site — environment variables
# These power the Stripe→Resend fulfillment function at api/stripe-webhook.js (MON-013).
# In production set these in Vercel → Project Settings → Environment Variables.
# For local testing with `vercel dev`, copy this file to `.env` (or `.env.local`).
# DO NOT commit real secrets.

# Stripe webhook signing secret (Stripe Dashboard → Developers → Webhooks → your endpoint).
# When unset, the function processes events WITHOUT verification (dev only — never ship unset).
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Resend API key (resend.com). Stored in the vault: Silver_Sage_Media → Account Information.
# When unset, the function skips the fulfillment email (logs a warning, still returns 200).
RESEND_API_KEY=re_xxx

# Download link placed in the fulfillment email. Defaults to the stable redirect below if unset;
# the redirect target lives in vercel.json (bump it when a new installer is hosted).
CONDUITAL_DOWNLOAD_URL=https://conduital.com/download/latest

# From address for the fulfillment email. Defaults to "Conduital <licenses@conduital.com>".
# The domain/sender must be verified in Resend before delivery works.
RESEND_FROM=Conduital <licenses@conduital.com>

# Optional: map Stripe Price IDs → Conduital tier. If a checkout sets
# metadata.conduital_tier, that wins and these are not needed.
STRIPE_GTD_PRICE_ID=
STRIPE_FULL_PRICE_ID=
