---
import Layout from '../layouts/Page.astro';

const version = '1.4.1';
const fileSize = '28.27 MB';
const sha256 = '833c0fc796207a8ce5782d033071e3c7c3eb7a15fc32988d7ebeccc4ffbaee56';
---

<Layout
	title="Download Conduital"
	description="Download the latest Conduital installer for Windows. For licensed users — purchase a license to unlock paid tiers."
>
	<p class="lead">
		The latest Windows installer for licensed users. If you haven't
		purchased a license yet, <a href="https://conduital.gumroad.com/l/conduital">grab one here</a>.
	</p>

	<div class="download-card">
		<div class="version-row">
			<span class="version-tag">v{version}</span>
			<span class="meta">Windows 10 / 11 · {fileSize}</span>
		</div>

		<a href="/download/latest" class="download-btn">
			Download Conduital v{version}
		</a>

		<div class="hash">
			<span class="hash-label">SHA-256</span>
			<code>{sha256}</code>
		</div>

		<p class="verify-note">
			Verify the download with
			<code>certutil -hashfile ConduitalSetup-{version}.exe SHA256</code>
			and compare against the hash above.
		</p>
	</div>

	<p class="footnote">
		Need a license? <a href="https://conduital.gumroad.com/l/conduital">Purchase Conduital →</a>
	</p>
</Layout>

<style>
	.lead {
		color: rgb(var(--gray-dark));
		line-height: 1.7;
		margin-bottom: 2rem;
	}
	.lead a {
		color: var(--brand-primary, #2563eb);
	}
	.download-card {
		border: 1px solid rgba(var(--gray-light), 0.6);
		border-radius: 12px;
		padding: 2rem;
		background: #fafafa;
	}
	.version-row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1.5rem;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.version-tag {
		display: inline-block;
		background: var(--brand-primary, #2563eb);
		color: white;
		font-weight: 700;
		padding: 0.25rem 0.7rem;
		border-radius: 6px;
		font-size: 0.9rem;
	}
	.meta {
		color: rgb(var(--gray-dark));
		font-size: 0.9rem;
	}
	.download-btn {
		display: block;
		text-align: center;
		background: #f59e0b;
		color: #1e3a5f;
		font-weight: 700;
		font-size: 1.15rem;
		padding: 1rem 2rem;
		border-radius: 8px;
		text-decoration: none;
		margin-bottom: 1.5rem;
	}
	.download-btn:hover {
		background: #d97706;
	}
	.hash {
		margin-bottom: 1rem;
	}
	.hash-label {
		display: block;
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: rgb(var(--gray-dark));
		margin-bottom: 0.25rem;
	}
	.hash code {
		display: block;
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.78rem;
		word-break: break-all;
		background: white;
		padding: 0.5rem 0.75rem;
		border-radius: 6px;
		border: 1px solid rgba(var(--gray-light), 0.6);
	}
	.verify-note {
		font-size: 0.85rem;
		color: rgb(var(--gray-dark));
		line-height: 1.6;
		margin: 0;
	}
	.verify-note code {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.8rem;
		background: white;
		padding: 0.1rem 0.4rem;
		border-radius: 4px;
		border: 1px solid rgba(var(--gray-light), 0.6);
	}
	.footnote {
		text-align: center;
		margin-top: 2rem;
		color: rgb(var(--gray-dark));
	}
	.footnote a {
		color: var(--brand-primary, #2563eb);
		font-weight: 600;
	}
</style>
