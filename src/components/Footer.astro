---
const today = new Date();
---

<footer>
	<div class="footer-content">
		<p class="copyright">
			&copy; {today.getFullYear()} Silver Sage, LLC. All rights reserved.
		</p>
		<div class="social-links">
			<a href="https://conduital.gumroad.com/l/conduital" target="_blank" rel="noopener">
				<span class="sr-only">Get Conduital on Gumroad</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="28" height="28">
					<path fill="currentColor" d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm3.248 17.5H8.752a.75.75 0 0 1-.75-.75V7.25a.75.75 0 0 1 .75-.75h6.496a.75.75 0 0 1 .75.75v9.5a.75.75 0 0 1-.75.75z"/>
				</svg>
			</a>
		</div>
		<p class="footer-tagline">
			Built with care for people who think deeply and work intentionally.
		</p>
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	.footer-content {
		max-width: 600px;
		margin: 0 auto;
	}
	.copyright {
		font-size: 0.9rem;
		margin-bottom: 1em;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-bottom: 1em;
	}
	.social-links a {
		text-decoration: none;
		color: rgb(var(--gray));
		transition: color 0.15s ease;
	}
	.social-links a:hover {
		color: rgb(var(--gray-dark));
	}
	.footer-tagline {
		font-size: 0.85rem;
		font-style: italic;
		opacity: 0.8;
	}
</style>
