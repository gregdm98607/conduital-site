---
import Analytics from '@vercel/analytics/astro';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	prev?: CollectionEntry<'blog'> | null;
	next?: CollectionEntry<'blog'> | null;
};

const { title, description, pubDate, updatedDate, heroImage, prev, next } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}			/* Hero overlay */
			.hero-overlay {
				position: relative;
				overflow: hidden;
				border-radius: 12px;
				margin-bottom: 2rem;
				max-width: 1020px;
				margin-left: auto;
				margin-right: auto;
			}
			.hero-overlay img {
				width: 100%;
				display: block;
			}
			.hero-title-overlay {
				position: absolute;
				bottom: 0;
				left: 0;
				right: 0;
				padding: 2rem 1.5rem 1.5rem;
				background: linear-gradient(transparent, rgba(30,58,95,0.85));
				color: white;
			}
			.hero-title-overlay h1 {
				font-size: 1.5rem;
				margin: 0;
				text-shadow: 0 1px 3px rgba(0,0,0,0.3);
			}			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}			/* Post CTA */
			.post-cta {
				text-align: center;
				padding: 2rem;
				background: var(--brand-light, #f0f7ff);
				border-radius: 12px;
				margin: 2rem 0;
			}
			.post-cta h3 {
				margin: 0 0 1rem;
				color: var(--brand-dark, #1e3a5f);
			}
			.post-cta .cta-button {
				display: inline-block;
				background: var(--brand-primary, #2563eb);
				color: white;
				font-weight: 700;
				padding: 0.75rem 1.5rem;
				border-radius: 8px;
				text-decoration: none;
				transition: background 0.15s ease;
			}
			.post-cta .cta-button:hover {
				background: #1d4ed8;
			}			/* Share buttons */
			.share-buttons {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				margin: 1.5rem 0;
				padding-top: 1.5rem;
				border-top: 1px solid #e5e7eb;
			}
			.share-buttons span {
				font-size: 0.9rem;
				color: rgb(var(--gray));
			}
			.share-btn {
				background: none;
				border: 1px solid #d1d5db;
				border-radius: 6px;
				padding: 0.5rem;
				cursor: pointer;
				display: flex;
				align-items: center;
				color: rgb(var(--gray));
				transition: background 0.15s ease;
			}
			.share-btn:hover {
				background: #f3f4f6;
			}			/* Back to blog link */
			.back-to-blog {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				color: var(--brand-primary, #2563eb);
				text-decoration: none;
				font-size: 0.9rem;
				font-weight: 600;
				margin-bottom: 1.5rem;
			}
			.back-to-blog:hover {
				text-decoration: underline;
			}
			/* Prev/Next nav */
			.post-nav {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1rem;
				margin: 2rem 0 1rem;
				padding-top: 1.5rem;
				border-top: 1px solid #e5e7eb;
			}
			.post-nav a {
				display: block;
				padding: 1rem;
				border: 1px solid #e5e7eb;
				border-radius: 8px;
				text-decoration: none;
				color: inherit;
				transition: background 0.15s ease;
			}
			.post-nav a:hover {
				background: #f9fafb;
			}
			.post-nav .nav-label {
				font-size: 0.8rem;
				color: rgb(var(--gray));
				margin-bottom: 0.25rem;
			}
			.post-nav .nav-title {
				font-weight: 600;
				color: var(--brand-dark, #1e3a5f);
			}
			.post-nav .nav-next {
				text-align: right;
			}
			.post-nav .nav-empty {
				visibility: hidden;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>				{heroImage && (
					<div class="hero-overlay">
						<Image width={1020} height={510} src={heroImage} alt="" />
						<div class="hero-title-overlay">
							<h1>{title}</h1>
						</div>
					</div>
				)}
				<div class="prose">
					<a href="/blog" class="back-to-blog">&larr; Back to Blog</a>
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						{!heroImage && <h1>{title}</h1>}
						<hr />
					</div>
					<slot />
					<!-- Post CTA -->
					<div class="post-cta">
						<h3>Ready to take control of your productivity?</h3>
						<a href="https://conduital.gumroad.com/l/conduital" class="cta-button">Get Conduital &rarr;</a>
					</div>

					<!-- Prev/Next navigation -->
					{(prev || next) && (
						<nav class="post-nav" aria-label="Post navigation">
							{prev ? (
								<a href={`/blog/${prev.id}/`} class="nav-prev">
									<div class="nav-label">&larr; Previous</div>
									<div class="nav-title">{prev.data.title}</div>
								</a>
							) : (
								<span class="nav-empty"></span>
							)}
							{next ? (
								<a href={`/blog/${next.id}/`} class="nav-next">
									<div class="nav-label">Next &rarr;</div>
									<div class="nav-title">{next.data.title}</div>
								</a>
							) : (
								<span class="nav-empty"></span>
							)}
						</nav>
					)}

					<!-- Share buttons -->
					<div class="share-buttons">
						<span>Share this post:</span>
						<button class="share-btn" data-share="twitter" aria-label="Share on Twitter/X">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
						</button>
						<button class="share-btn" data-share="linkedin" aria-label="Share on LinkedIn">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
						</button>
						<button class="share-btn" data-share="copy" aria-label="Copy link">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
						</button>
					</div>
				</div>
			</article>
		</main>
		<Footer />
		<Analytics />
		<script>
			document.querySelectorAll('.share-btn').forEach(btn => {
				btn.addEventListener('click', () => {
					const url = encodeURIComponent(window.location.href);
					const title = encodeURIComponent(document.title);
					const type = btn.dataset.share;
					if (type === 'twitter') {
						window.open(`https://twitter.com/intent/tweet?text=${title}&url=${url}`, '_blank');
					} else if (type === 'linkedin') {
						window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${url}`, '_blank');
					} else if (type === 'copy') {
						navigator.clipboard.writeText(window.location.href);
						const original = btn.innerHTML;
						btn.textContent = '✓ Copied!';
						setTimeout(() => { btn.innerHTML = original; }, 2000);
					}
				});
			});
		</script>
	</body>
</html>